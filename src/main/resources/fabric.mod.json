	"authors": [
		"PhaseZenith"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/FabricMC/fabric-example-mod"
	},
	"license": "CC0-1.0",
	"icon": "assets/roofed/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"net.phase.roofed.Roofed"
		],
		"fabric-datagen": [
			"net.phase.roofed.RoofedDataGenerator"
		],
		"client": [
			"net.phase.roofed.RoofedClient"
		]
	},
	"mixins": [
		"roofed.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21",
		"java": ">=21",
		"fabric-api": "*"
